+  flex-direction: column;
+  gap: 0.6vh;
+  max-width: 58vw;
+}
+
+.headline {
+  display: inline-block;
+  padding: 0.45em 0.9em;
+  background: var(--spravy-headline-bg);
+  color: var(--spravy-text);
+  font-weight: 700;
+  border-radius: 0.4vw;
+  font-size: 2.2vw;
